generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENT)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  reservations Reservation[]
  payments     Payment[]
  loyaltyCard  LoyaltyCard?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  CLIENT
}

// ─── Planning / Agenda ──────────────────────────────

model CourseType {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int      @default(55) // minutes
  maxPersons  Int      @default(6)
  price       Float
  createdAt   DateTime @default(now())

  timeSlots TimeSlot[]
}

model TimeSlot {
  id           String     @id @default(cuid())
  courseTypeId  String
  startTime    DateTime
  endTime      DateTime
  maxPersons   Int        @default(6)
  isActive     Boolean    @default(true)
  recurrence   Recurrence?
  createdAt    DateTime   @default(now())

  courseType    CourseType    @relation(fields: [courseTypeId], references: [id], onDelete: Cascade)
  reservations Reservation[]
}

enum Recurrence {
  NONE
  WEEKLY
  BIWEEKLY
}

// ─── Reservations ───────────────────────────────────

model Reservation {
  id         String            @id @default(cuid())
  userId     String
  timeSlotId String
  status     ReservationStatus @default(CONFIRMED)
  paymentId  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id])
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
  COMPLETED
}

// ─── Payments ───────────────────────────────────────

model Payment {
  id               String        @id @default(cuid())
  userId           String
  amount           Float
  currency         String        @default("eur")
  status           PaymentStatus @default(PENDING)
  stripeSessionId  String?       @unique
  stripePaymentId  String?       @unique
  type             PaymentType
  packageName      String?
  sessionsTotal    Int?
  sessionsUsed     Int           @default(0)
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations Reservation[]
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentType {
  SINGLE
  PACK_5
  PACK_10
  ABONNEMENT_8
  ABONNEMENT_12
  ABONNEMENT_16
  DISCOVERY
}

// ─── Loyalty ────────────────────────────────────────

model LoyaltyCard {
  id            String   @id @default(cuid())
  userId        String   @unique
  points        Int      @default(0)
  totalSessions Int      @default(0)
  tier          LoyaltyTier @default(BRONZE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  history LoyaltyHistory[]
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model LoyaltyHistory {
  id            String   @id @default(cuid())
  loyaltyCardId String
  points        Int
  reason        String
  createdAt     DateTime @default(now())

  loyaltyCard LoyaltyCard @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
}
